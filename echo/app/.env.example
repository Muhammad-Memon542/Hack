# --- Persistence -----------------------------------------------------------
# MongoDB Atlas connection string. When set, the social/market store and the
# deposit ledger persist to MongoDB; when unset, they fall back to a local
# file-backed store (.data/*.json) so the app still runs with no database.
# Free M0 tier is plenty — see README notes. Example:
#   mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=""
MONGODB_DB="echo"

# PostgreSQL (Supabase) connection string — legacy Prisma/SIWS path (optional).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/echo"

# Secret used to sign SIWS session JWTs
JWT_SECRET="change-me-to-a-long-random-string"

# Server-side RPC endpoint (Helius / Triton). Used by the webhook ingestor.
RPC_URL="https://api.devnet.solana.com"

# Shared secret configured on the Helius webhook (sent as the Authorization header)
HELIUS_WEBHOOK_SECRET="change-me"

# Client-side RPC endpoint
NEXT_PUBLIC_RPC_URL="https://api.devnet.solana.com"

# Deployed echo_protocol program id
NEXT_PUBLIC_PROGRAM_ID="ELThikt285QiyLBWPNiGbgTTzGvjvQhYjrV33VC8ZyoD"

# Settlement mint (mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v)
NEXT_PUBLIC_USDC_MINT="EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
NEXT_PUBLIC_USDC_DECIMALS="6"

# Unifold multi-chain USDC deposits. SECRET key is server-side only (used by
# @unifold/node in API routes); never prefix with NEXT_PUBLIC_.
UNIFOLD_SECRET_KEY=""
# Destination for bridged USDC (sandbox = Base Sepolia USDC; live would be Solana)
UNIFOLD_DESTINATION_CHAIN_TYPE="ethereum"
UNIFOLD_DESTINATION_CHAIN_ID="84532"
UNIFOLD_DESTINATION_TOKEN_ADDRESS="0x036cbd53842c5426634e7929541ec2318f3dcf7e"
# Treasury address that receives bridged USDC (your team's EVM address)
UNIFOLD_TREASURY_ADDRESS="0xYourTreasuryAddress"
# Webhook endpoint signing secret from the Unifold dashboard
UNIFOLD_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"

# --- Auth0 (login) ---------------------------------------------------------
# Create a "Regular Web Application" in the Auth0 dashboard, then set:
#   Allowed Callback URLs: http://localhost:3999/auth/callback
#   Allowed Logout URLs:   http://localhost:3999
#   Allowed Web Origins:   http://localhost:3999
# AUTH0_SECRET: generate with `openssl rand -hex 32`.
# The SDK auto-mounts /auth/login, /auth/logout, /auth/callback via middleware.
# When these are unset the app runs without auth (login page offers demo mode).
AUTH0_SECRET=""
APP_BASE_URL="http://localhost:3999"
AUTH0_DOMAIN=""          # e.g. dev-xxxx.us.auth0.com (no https://)
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
NEXT_PUBLIC_AUTH0_ENABLED="false"   # set "true" once the three values are filled
